{
  "manifest_version": 3,
  "name": "ResumePR",
  "version": "0.1.0",
  "description": "Chrome extension shell for extracting job descriptions and syncing with ResumePR.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*.linkedin.com/*",
    "https://*.greenhouse.io/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.linkedin.com/jobs/*",
        "https://*.greenhouse.io/*",
        "https://*.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.workday.com/*",
        "https://*.indeed.com/*",
        "https://*.glassdoor.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
